{
  "name": "bhrefs — SEO Tools for AI Agents",
  "description": "A suite of SEO tools built for AI agents. Currently live: Backlink Finder — discover every domain linking to any site using Common Crawl hyperlink graph data. Gap analysis to find competitor backlinks you're missing.",
  "version": "0.1.0",
  "endpoints": [
    {
      "path": "/backlinks/{domain}",
      "method": "GET",
      "description": "Get all backlinks for a domain with enrichment data",
      "price": "$0.10 USDC",
      "response_type": "application/json"
    },
    {
      "path": "/find",
      "method": "GET",
      "description": "Quick backlink lookup for a domain",
      "price": "$0.05 USDC",
      "response_type": "application/json"
    },
    {
      "path": "/gap?yours={domain}&competitor={domain}",
      "method": "GET",
      "description": "Gap analysis: domains linking to competitor but not to you",
      "price": "$0.15 USDC",
      "response_type": "application/json"
    },
    {
      "path": "/preview/{domain}",
      "method": "GET",
      "description": "Free preview: top 5 backlinks for cached domains",
      "price": "free",
      "response_type": "application/json"
    },
    {
      "path": "/domains",
      "method": "GET",
      "description": "List all available cached domains (free)",
      "price": "free",
      "response_type": "application/json"
    },
    {
      "path": "/health",
      "method": "GET",
      "description": "Health check (free)",
      "price": "free",
      "response_type": "application/json"
    }
  ],
  "payment": {
    "protocol": "x402",
    "network": "eip155:8453",
    "currency": "USDC",
    "wallet": "0x2D8cFC122D13971EEf8cfB4CBC047F527eB76FAd"
  }
}
